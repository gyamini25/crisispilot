# Copy to .env. All values are optional — backend runs in stub mode without them.
GEMINI_API_KEY=
MONGODB_URI=
MONGODB_DB=crisispilot

# Dynatrace MCP (partner integration). Leave blank to keep tool calls scripted.
# DT_ENVIRONMENT MUST be the platform URL — https://<env-id>.apps.dynatrace.com —
# NOT the account-management URL (myaccount.dynatrace.com/account/...).
DT_ENVIRONMENT=
DT_PLATFORM_TOKEN=

# Simulation controls
CRISISPILOT_AUTOSTART_SIMULATOR=true
CRISISPILOT_INCIDENT_INTERVAL_SECONDS=45
